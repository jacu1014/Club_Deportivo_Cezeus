{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/((?!sitemap.xml|robots.txt|og-image.jpg|favicon|assets).*)",
      "destination": "/index.html"
    }
  ]
}